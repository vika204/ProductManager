<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProductManager.Pages.WarehousesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:ProductManager.UIModels;assembly=ProductManager.UIModels"
    xmlns:pages="clr-namespace:ProductManager.Pages"
    x:DataType="pages:WarehousesPage"
    Title="Warehouses"
    Style="{StaticResource AppPageStyle}">

    <CollectionView
        ItemsSource="{Binding Warehouses}"
        Margin="16"
        SelectionMode="Single"
        SelectionChanged="WarehouseSelected">

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:WarehouseUIModel">
                <Border Style="{StaticResource WarehouseCardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="{Binding Name}"
                            Style="{StaticResource MainCardTitleStyle}" />

                        <Label
                            Text="{Binding Location, Converter={StaticResource EnumToDisplayName}}"
                            Style="{StaticResource SecondaryInfoStyle}"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>