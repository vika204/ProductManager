<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProductManager.Pages.WarehouseDetailsPage"
    x:Name="WarehouseDetailsPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:ProductManager.DTOModels.Product;assembly=ProductManager.DTOModels"
    xmlns:vms="clr-namespace:ProductManager.ViewModels"
    x:DataType="vms:WarehouseDetailsViewModel"
    Title="Warehouse Details"
    IsEnabled="{Binding IsNotBusy}"
    Style="{StaticResource AppPageStyle}">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Warehouse details section -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16,16,16,8" Spacing="12">
                <Border Style="{StaticResource WarehouseCardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="{Binding CurrentWarehouse.Name}"
                            Style="{StaticResource MainCardTitleStyle}" />

                        <Label Text="Location" Style="{StaticResource SectionCaptionStyle}" />
                        <Label
                            Text="{Binding CurrentWarehouse.Location, Converter={StaticResource EnumToDisplayName}}"
                            Style="{StaticResource ValueTextStyle}" />

                        <Label Text="Total value" Style="{StaticResource SectionCaptionStyle}" />
                        <Label
                            Text="{Binding CurrentWarehouse.TotalValue, StringFormat='{}{0:0.00}'}"
                            Style="{StaticResource ValueTextStyle}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button
                        Grid.Column="0"
                        Text="Edit warehouse"
                        Command="{Binding EditWarehouseCommand}" />

                    <Button
                        Grid.Column="1"
                        Text="Delete warehouse"
                        Command="{Binding DeleteWarehouseCommand}" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout
            Grid.Row="1"
            Padding="16,0,16,8"
            Spacing="10">

            <Border Style="{StaticResource SearchInputBorderStyle}">
                <Entry
                    Placeholder="Search products"
                    Text="{Binding SearchText}" />
            </Border>

            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <Border
                    Grid.Column="0"
                    Style="{StaticResource SearchInputBorderStyle}">
                    <Picker
                        Title="Sort by"
                        TextColor="{StaticResource TextPrimary}"
                        TitleColor="{StaticResource TextSecondary}"
                        ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSortOption}" />
                </Border>

                <Button
                    Grid.Column="1"
                    Text="Apply"
                    Command="{Binding ApplyFiltersCommand}" />

                <Button
                    Grid.Column="2"
                    Text="Add product"
                    Command="{Binding AddProductCommand}" />
            </Grid>
        </VerticalStackLayout>

        <RefreshView
            Grid.Row="2"
            Command="{Binding RefreshDataCommand}">
            <CollectionView
                Margin="16,0,16,16"
                ItemsSource="{Binding Products}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProductListDTO">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem
                                        BackgroundColor="Red"
                                        Text="Delete"
                                        Command="{Binding Source={x:Reference WarehouseDetailsPageRoot}, Path=BindingContext.DeleteProductCommand}"
                                        CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border Style="{StaticResource ProductCardStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference WarehouseDetailsPageRoot}, Path=BindingContext.LoadProductCommand}"
                                        CommandParameter="{Binding Id}" />
                                </Border.GestureRecognizers>

                                <VerticalStackLayout Spacing="6">
                                    <Label
                                        Text="{Binding Name}"
                                        Style="{StaticResource MainCardTitleStyle}" />

                                    <Label
                                        Text="{Binding Category, Converter={StaticResource EnumToDisplayName}}"
                                        Style="{StaticResource SecondaryInfoStyle}" />

                                    <Label
                                        Text="{Binding Quantity, StringFormat='Quantity: {0}'}"
                                        Style="{StaticResource ValueTextStyle}" />

                                    <Label
                                        Text="{Binding Price, StringFormat='Price: {0:0.00}'}"
                                        Style="{StaticResource ValueTextStyle}" />

                                    <Label
                                        Text="{Binding TotalValue, StringFormat='Total value: {0:0.00}'}"
                                        Style="{StaticResource ValueTextStyle}" />
                                </VerticalStackLayout>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <BoxView
            Grid.RowSpan="3"
            BackgroundColor="Gray"
            InputTransparent="False"
            IsVisible="{Binding IsBusy}"
            Opacity="0.2" />

        <ActivityIndicator
            Grid.RowSpan="3"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center" />
    </Grid>
</ContentPage>